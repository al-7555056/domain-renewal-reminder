# 爱自由域名管理 - 前端环境变量示例

# ============================================
# 本地开发环境
# ============================================

# API URL for the backend (本地开发)
VITE_API_URL=http://localhost:8787/api

# ============================================
# 生产环境配置说明
# ============================================

# 生产环境的 API URL 应该在 Cloudflare Pages Dashboard 中配置
# 不要在代码中硬编码生产环境的 URL
# 
# 配置步骤：
# 1. 登录 Cloudflare Dashboard
# 2. 进入 Pages > 你的项目
# 3. Settings > Environment variables
# 4. 添加变量：
#    - Variable name: VITE_API_URL
#    - Value: https://your-worker-url.workers.dev/api
#    - Environment: Production
# 5. 保存并重新部署

# ============================================
# 注意事项
# ============================================

# 1. 这个文件仅用于本地开发
# 2. 不要将包含生产 URL 的 .env 文件提交到 Git
# 3. frontend/.env 已在 .gitignore 中排除
# 4. 生产环境使用 Cloudflare Pages 环境变量
