# 爱自由域名管理 - 环境变量示例

# ============================================
# Cloudflare Workers 环境变量（使用 wrangler secret）
# ============================================

# 管理员密码（用于访问管理员面板）
# 设置方法：wrangler secret put ADMIN_PASSWORD
# 建议：至少16字符，包含大小写字母、数字和特殊字符
ADMIN_PASSWORD=your_strong_admin_password_here

# 加密密钥（用于加密 SMTP 密码等敏感数据）
# 设置方法：wrangler secret put ENCRYPTION_KEY
# 必须是64个十六进制字符（32字节）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# 智谱国际版 API Key（用于 AI 域名导入识别）
# 设置方法：wrangler secret put ZAI_API_KEY
ZAI_API_KEY=your_zai_api_key_here

# 智谱国际版 API Base URL（可选，默认已内置）
# 如需显式设置，可使用：
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# 智谱视觉模型（可选，默认 GLM-4.6V-Flash）
ZAI_VISION_MODEL=GLM-4.6V-Flash

# ============================================
# 前端环境变量（Cloudflare Pages Dashboard）
# ============================================

# API 基础 URL（你的 Cloudflare Worker URL）
# 在 Cloudflare Pages Dashboard 中配置：
# Settings > Environment variables > Production
# Variable name: VITE_API_URL
# Value: https://your-worker-url.workers.dev/api
VITE_API_URL=https://your-worker-url.workers.dev/api

# ============================================
# 开发环境变量（frontend/.env）
# ============================================

# 本地开发时的 API URL
# 这个文件仅用于本地开发，不要提交到 Git
VITE_API_URL=http://localhost:8787/api

# ============================================
# 注意事项
# ============================================

# 1. 不要将实际的密钥提交到 Git 仓库
# 2. 在生产环境使用 wrangler secret 设置敏感信息
# 3. 前端环境变量应在 Cloudflare Pages Dashboard 中配置
# 4. frontend/.env 文件仅用于本地开发，已在 .gitignore 中排除
# 5. 定期更换密钥以提高安全性
